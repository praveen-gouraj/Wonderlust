<style>
    .navbar {
        background-color: #fff;
    }

    .fa-compass {
        color: #fc424d;
        font-size: 2rem;
    }

    .search-form {
        max-width: 460px;
    }

    .search-btn:hover {
        background: #e63946;
        color: white;
    }

    @media (max-width:767px) {
        .search-form {
            order: 1;
            width: 100%;
            max-width: 100%;
            margin: 1rem 0;
        }

        .search-form .search-btn {
            width: 100%;
        }

        .navbar-nav {
            width: 100%;
            text-align: center;
        }

        .navbar-nav .nav-link {
            padding: .6rem 0;
            white-space: normal;
        }

    }
</style>

<nav class="navbar navbar-expand-md border-bottom sticky-top">

    <div class="container-fluid px-3">

        <!-- Logo -->
        <a class="navbar-brand" href="/listings">
            <i class="fa-regular fa-compass"></i>
        </a>

        <button class="navbar-toggler d-md-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#mobileMenu">

            <i class="fa-solid fa-bars"></i>

        </button>
        <div class="d-none d-md-flex flex-grow-1 align-items-center gap-3 ms-3">

            <!-- Left -->
            <div class="navbar-nav">
                <a class="nav-link" href="/listings">Explore</a>
            </div>

            <!-- Center -->
            <form class="d-flex mx-auto search-form" action="/listings" method="GET">

                <input class="form-control me-2 search-inp" type="search" name="search"
                    placeholder="Search destinations" value="<%= typeof search !== 'undefined' ? search : '' %>">

                <button class="btn btn-success search-btn">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    Search
                </button>

            </form>

            <!-- Right -->
            <div class="navbar-nav ms-auto flex-row flex-wrap justify-content-end gap-1">

                <a class="nav-link" href="/listings/new">
                    Airbnb your home
                </a>

                <% if(!currUser){ %>

                    <a class="nav-link" href="/signup">
                        <b>Sign up</b>
                    </a>

                    <a class="nav-link" href="/login">
                        <b>Log in</b>
                    </a>

                    <% } else { %>

                        <a class="nav-link" href="/logout">
                            <b>Log out</b>
                        </a>

                        <% } %>

            </div>

        </div>

    </div>

</nav>
<div class="offcanvas offcanvas-end" tabindex="-1" id="mobileMenu">

    <div class="offcanvas-header">

        <h5 class="offcanvas-title">
            Wanderlust
        </h5>

        <button type="button" class="btn-close" data-bs-dismiss="offcanvas">
        </button>

    </div>

    <div class="offcanvas-body">

        <!-- Search -->

        <form action="/listings" method="GET" class="mb-4 d-grid gap-2">

            <input class="form-control" type="search" name="search" placeholder="Search destinations">

            <button class="btn btn-success search-btn w-100">

                <i class="fa-solid fa-magnifying-glass"></i>

                Search

            </button>

        </form>

        <a class="nav-link mb-3" href="/listings">
            Explore
        </a>

        <a class="nav-link mb-3" href="/listings/new">
            Airbnb your home
        </a>

        <% if(!currUser){ %>

            <a class="nav-link mb-3" href="/signup">
                Sign up
            </a>

            <a class="nav-link" href="/login">
                Log in
            </a>

            <% } else { %>

                <a class="nav-link" href="/logout">
                    Log out
                </a>

                <% } %>

    </div>

</div>