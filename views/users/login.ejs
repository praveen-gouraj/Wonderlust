<% layout("/layouts/boilerplate") %>

    <div class="row justify-content-center mt-4 auth-shell">
        <div class="col-12 col-sm-10 col-md-8 col-lg-6 col-xl-5 ui-panel">
            <h1 class="mb-4">Login to Wanderlust</h1>
            <form action="/login" method="POST" novalidate>
                <div class="mb-3">
                    <label for="username" class="form-label">Username</label>
                    <input name="username" type="text" id="username" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label for="password" class="form-label">Password</label>
                    <input name="password" type="password" id="password" class="form-control" required />
                </div>
                <div class="d-grid d-sm-flex mt-4">
                    <button class="btn btn-success px-4">Login</button>
                </div>
            </form>
        </div>
    </div>